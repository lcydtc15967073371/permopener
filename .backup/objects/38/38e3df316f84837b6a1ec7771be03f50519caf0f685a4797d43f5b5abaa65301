/**
 * PermOpener - 权限全开工具
 *
 * 打开即自动执行，无需任何手动操作。
 * 通过 Shizuku 获得 ADB shell 级别权限后，执行：
 *   pm grant   → 授予 Android 标准权限
 *   appops set → 授予 AppOps 权限
 *   settings   → 修改系统设置
 *
 * 这等价于在手机里内置了 adb shell 命令。
 */
class MainActivity : ComponentActivity() {

    companion object {
        private const val TAG = "PermOpener"
        private const val SHIZUKU_REQUEST_CODE = 1001
        private const val PKG = "com.permopener"
    }

    private val logs = mutableListOf<String>()

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        log("")
        log("╔══════════════════════════════════╗")
        log("║     PermOpener v1.1              ║")
        log("║     权限全开 · 内置 adb 命令     ║")
        log("╚══════════════════════════════════╝")
        log("设备: ${Build.MODEL}, SDK: ${Build.VERSION.SDK_INT}")
        log("")

        if (!shizukuPing()) {
            log("✗ Shizuku 未安装或未运行")
            log("  请先安装 Shizuku App (shizuku.rikka.app)")
            log("  打开 Shizuku → 启动服务 → 再打开本应用")
            toast("请先安装并启动 Shizuku")
            finishAfter(5000)
            return
        }

        if (!shizukuGranted()) {
            log("→ Shizuku 未授权，正在请求授权...")
            shizukuRequest()
            return
        }

        log("✓ Shizuku 已授权，开始全自动执行...")
        executeAll()
    }

    override fun onActivityResult(requestCode: Int, resultCode: Int, data: Intent?) {
        super.onActivityResult(requestCode, resultCode, data)
        if (requestCode == SHIZUKU_REQUEST_CODE) {
            if (shizukuGranted()) {
                log("✓ Shizuku 授权成功，开始执行...")
                executeAll()
            } else {
                log("✗ Shizuku 授权被拒绝，无法继续")
                toast("Shizuku 授权被拒绝")
                finishAfter(3000)
            }
        }
    }

    // ==================== Shizuku 工具 ====================

    private fun shizukuPing(): Boolean = try {
        val c = Class.forName("rikka.shizuku.Shizuku")
        c.getMethod("ping").invoke(null) as Boolean
    } catch (_: Exception) { false }

    private fun shizukuGranted(): Boolean = try {
        val c = Class.forName("rikka.shizuku.Shizuku")
        val r = c.getMethod("checkSelfPermission").invoke(null) as Int
        r == 0
    } catch (_: Exception) { false }

    private fun shizukuRequest() = try {
        val c = Class.forName("rikka.shizuku.Shizuku")
        c.getMethod("requestPermission", Int::class.javaPrimitiveType)
            .invoke(null, SHIZUKU_REQUEST_CODE)
    } catch (e: Exception) {
        log("✗ 请求 Shizuku 授权异常: ${e.message}")
        finishAfter(3000)
    }

    /**
     * 通过反射调用 Shizuku.newProcess("sh") 获取根 shell
     * 等价于内置了 adb shell
     */
    private fun shExec(cmd: String): ShResult {
        try {
            val c = Class.forName("rikka.shizuku.Shizuku")
            val m = c.getDeclaredMethod(
                "newProcess",
                Array<String>::class.java, Array<String>::class.java, String::class.java
            )
            m.isAccessible = true
            val proc = m.invoke(null, arrayOf("sh"), null, null) as Process

            val os = proc.outputStream
            // 每条命令后输出退出码，精确判断
            os.write("$cmd 2>&1\necho \"__EXIT__:\$?\"\n".toByteArray())
            os.write("exit\n".toByteArray())
            os.flush()

            val rdr = BufferedReader(InputStreamReader(proc.inputStream))
            val out = rdr.readText()
            val exitCode = proc.waitFor()

            // 从输出中提取 "__EXIT__:0" 等
            val ec = Regex("__EXIT__:(\\d+)").find(out)?.groupValues?.get(1)?.toIntOrNull() ?: exitCode
            val clean = out.replace(Regex("__EXIT__:\\d+\\s*"), "").trim()
            return ShResult(ec, clean)
        } catch (e: Exception) {
            return ShResult(-1, "ERR: ${e.message}")
        }
    }

    data class ShResult(val exitCode: Int, val output: String)

    // ==================== 权限命令列表 ====================

    /** 1) pm grant 可授予的 Android 权限（adb shell pm grant 等价） */
    private val pmGrants = listOf(
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_PHONE_STATE",
        "android.permission.CALL_PHONE",
        "android.permission.READ_CALL_LOG",
        "android.permission.WRITE_CALL_LOG",
        "android.permission.ADD_VOICEMAIL",
        "android.permission.USE_SIP",
        "android.permission.SEND_SMS",
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_WAP_PUSH",
        "android.permission.RECEIVE_MMS",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.GET_ACCOUNTS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.BODY_SENSORS",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.NFC",
        "android.permission.VIBRATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.CHANGE_NETWORK_STATE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE_CAMERA",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.ANSWER_PHONE_CALLS",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
    )

    /** 2) appops set 需要的 AppOps */
    private val appOps = listOf(
        "android:mock_location",
        "android:post_notifications",
        "SYSTEM_ALERT_WINDOW",
        "WRITE_SETTINGS",
        "START_ACTIVITY_BACKGROUND",
        "START_FOREGROUND",
        "GET_USAGE_STATS",
        "REQUEST_INSTALL_PACKAGES",
        "GET_NOTIFICATION",
        "MANAGE_EXTERNAL_STORAGE",
        "android:camera",
        "android:record_audio",
        "android:fine_location",
        "android:read_phone_state",
        "WAKE_LOCK",
        "android:body_sensors",
        "android:coarse_location",
        "android:read_external_storage",
        "android:write_external_storage",
        "android:read_contacts",
        "android:write_contacts",
        "android:read_call_log",
        "android:write_call_log",
        "android:read_sms",
        "android:write_sms",
        "android:receive_sms",
        "android:send_sms",
    )

    /** 3) settings 命令 */
    private val settingsCmds = listOf(
        "settings put secure install_non_market_apps 1",
        "settings put global development_settings_enabled 1",
    )

    /** 4) 特殊 shell 命令 */
    private val shellCmds = listOf(
        // 直接给 pm grant（部分权限需要 --user 0 参数）
        "pm grant $PKG android.permission.SYSTEM_ALERT_WINDOW",
    )

    // ==================== 执行引擎 ====================

    private fun executeAll() {
        var ok = 0; var fail = 0

        // === 阶段 1: pm grant ===
        log("")
        log("── 阶段 1/4: pm grant ──")
        for (perm in pmGrants) {
            val r = shExec("pm grant $PKG $perm 2>&1")
            if (r.exitCode == 0) { ok++ }
            else { fail++; log("  ~ $perm → ${r.exitCode} ${r.output.take(60)}") }
        }
        log("  ✓ pm grant: 成功=$ok 失败=$fail")

        // === 阶段 2: appops set ===
        log("")
        log("── 阶段 2/4: appops set ──")
        for (op in appOps) {
            val r = shExec("appops set $PKG $op allow 2>&1")
            if (r.exitCode == 0) { ok++ }
            else { fail++; log("  ~ $op → ${r.exitCode} ${r.output.take(60)}") }
        }
        log("  ✓ appops set: 累计成功=$ok 累计失败=$fail")

        // === 阶段 3: settings ===
        log("")
        log("── 阶段 3/4: settings ──")
        for (cmd in settingsCmds) {
            val r = shExec("$cmd 2>&1")
            if (r.exitCode == 0) ok++ else { fail++; log("  ~ $cmd → ${r.exitCode}") }
        }
        log("  ✓ settings: 累计成功=$ok 累计失败=$fail")

        // === 阶段 4: 额外 shell ===
        log("")
        log("── 阶段 4/4: 额外命令 ──")
        for (cmd in shellCmds) {
            val r = shExec("$cmd 2>&1")
            if (r.exitCode == 0) ok++ else { fail++; log("  ~ $cmd → ${r.exitCode}") }
        }

        // === 汇总 ===
        log("")
        log("╔══════════════════════════════════╗")
        log("║  全部完成！                      ║")
        log("║  成功: $ok  失败: $fail            ║")
        log("╚══════════════════════════════════╝")
        log("")
        log("查看完整日志: adb logcat -s PermOpener")
        log("某些权限需重启 App 生效。")

        toast("权限全开完成！成功 $ok 项 失败 $fail 项")

        // 3 秒后自动关闭
        finishAfter(3000)
    }

    // ==================== 辅助 ====================

    private fun log(msg: String) {
        Log.d(TAG, msg)
        logs.add(msg)
        println("[PermOpener] $msg")
    }

    private fun toast(msg: String) {
        runOnUiThread { Toast.makeText(this, msg, Toast.LENGTH_LONG).show() }
    }

    private fun finishAfter(ms: Long) {
        window?.decorView?.postDelayed({ finish() }, ms)
    }
}


/**
 * PermOpener - 权限全开工具
 *
 * 核心方案：通过 Shizuku 获得 ADB shell 权限后，直接执行：
 *   pm grant com.permopener <permission>        # 授予 Android 权限
 *   appops set com.permopener <op> allow         # 授予 AppOps 权限
 *
 * 这等价于 "内置了 adb 命令"。
 */
class MainActivity : ComponentActivity() {

    companion object {
        private const val TAG = "PermOpener"
        private const val SHIZUKU_REQUEST_CODE = 1001
        private const val PACKAGE = "com.permopener"
    }

    // ===== 通过 pm grant 可授予的 Android 权限（adb shell pm grant） =====
    private val pmGrantPermissions = listOf(
        // 位置
        Manifest.permission.ACCESS_FINE_LOCATION,
        Manifest.permission.ACCESS_COARSE_LOCATION,
        // 存储（高版本用 Media 权限）
        Manifest.permission.READ_EXTERNAL_STORAGE,
        Manifest.permission.WRITE_EXTERNAL_STORAGE,
        // 相机 & 麦克风
        Manifest.permission.CAMERA,
        Manifest.permission.RECORD_AUDIO,
        // 电话
        Manifest.permission.READ_PHONE_STATE,
        Manifest.permission.CALL_PHONE,
        Manifest.permission.READ_CALL_LOG,
        Manifest.permission.WRITE_CALL_LOG,
        Manifest.permission.ADD_VOICEMAIL,
        Manifest.permission.USE_SIP,
        // 短信
        Manifest.permission.SEND_SMS,
        Manifest.permission.RECEIVE_SMS,
        Manifest.permission.READ_SMS,
        Manifest.permission.RECEIVE_WAP_PUSH,
        Manifest.permission.RECEIVE_MMS,
        // 通讯录
        Manifest.permission.READ_CONTACTS,
        Manifest.permission.WRITE_CONTACTS,
        Manifest.permission.GET_ACCOUNTS,
        // 日历
        Manifest.permission.READ_CALENDAR,
        Manifest.permission.WRITE_CALENDAR,
        // 传感器
        Manifest.permission.BODY_SENSORS,
        Manifest.permission.ACTIVITY_RECOGNITION,
        // 通知
        Manifest.permission.POST_NOTIFICATIONS,
        // 蓝牙
        Manifest.permission.BLUETOOTH,
        Manifest.permission.BLUETOOTH_ADMIN,
        Manifest.permission.BLUETOOTH_CONNECT,
        Manifest.permission.BLUETOOTH_SCAN,
        Manifest.permission.BLUETOOTH_ADVERTISE,
        // NFC
        Manifest.permission.NFC,
        // 其他
        Manifest.permission.VIBRATE,
        Manifest.permission.FOREGROUND_SERVICE,
        Manifest.permission.ACCESS_NETWORK_STATE,
        Manifest.permission.ACCESS_WIFI_STATE,
        Manifest.permission.CHANGE_WIFI_STATE,
        Manifest.permission.CHANGE_NETWORK_STATE,
    )

    // ===== 通过 appops set 可授予的权限（adb shell appops set） =====
    private val appOpsCommands = listOf(
        "appops set $PACKAGE android:mock_location allow",
        "appops set $PACKAGE android:post_notifications allow",
        "appops set $PACKAGE SYSTEM_ALERT_WINDOW allow",
        "appops set $PACKAGE WRITE_SETTINGS allow",
        "appops set $PACKAGE START_ACTIVITY_BACKGROUND allow",
        "appops set $PACKAGE START_FOREGROUND allow",
        "appops set $PACKAGE GET_USAGE_STATS allow",
        "appops set $PACKAGE REQUEST_INSTALL_PACKAGES allow",
        "appops set $PACKAGE GET_NOTIFICATION allow",
        "appops set $PACKAGE MANAGE_EXTERNAL_STORAGE allow",
        "appops set $PACKAGE android:camera allow",
        "appops set $PACKAGE android:record_audio allow",
        "appops set $PACKAGE android:fine_location allow",
        "appops set $PACKAGE android:read_phone_state allow",
        "appops set $PACKAGE WAKE_LOCK allow",
        "appops set $PACKAGE android:body_sensors allow",
    )

    private val logLines = mutableListOf<String>()

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        log("=== PermOpener v1.0 ===")
        log("目标: 通过 Shizuku 内置 adb 命令全开权限")
        log("")

        // 检查 Shizuku 是否可用
        if (!isShizukuAvailable()) {
            log("✗ Shizuku 不可用！请先安装 Shizuku App")
            log("   下载: https://shizuku.rikka.app/download/")
            log("   安装后打开 Shizuku -> 启动服务 -> 再打开本应用")
            Toast.makeText(this, "请先安装并启动 Shizuku", Toast.LENGTH_LONG).show()
            finish()
            return
        }

        // 检查 Shizuku 授权
        if (!checkShizukuPermission()) {
            log("→ 正在请求 Shizuku 授权...")
            requestShizukuPermission()
            return
        }

        // Shizuku 已授权，直接执行
        executeAll()
    }

    override fun onActivityResult(requestCode: Int, resultCode: Int, data: Intent?) {
        super.onActivityResult(requestCode, resultCode, data)
        if (requestCode == SHIZUKU_REQUEST_CODE) {
            if (checkShizukuPermission()) {
                log("✓ Shizuku 授权成功，开始执行...")
                executeAll()
            } else {
                log("✗ Shizuku 授权被拒绝")
                Toast.makeText(this, "Shizuku 授权被拒绝", Toast.LENGTH_LONG).show()
                finish()
            }
        }
    }

    // ==================== Shizuku 工具方法 ====================

    private fun isShizukuAvailable(): Boolean {
        return try {
            val cls = Class.forName("rikka.shizuku.Shizuku")
            val method = cls.getMethod("ping")
            method.invoke(null) as Boolean
        } catch (e: Exception) {
            false
        }
    }

    private fun checkShizukuPermission(): Boolean {
        return try {
            val cls = Class.forName("rikka.shizuku.Shizuku")
            val method = cls.getMethod("checkSelfPermission")
            val result = method.invoke(null) as Int
            result == 0  // GRANTED
        } catch (e: Exception) {
            false
        }
    }

    private fun requestShizukuPermission() {
        try {
            val cls = Class.forName("rikka.shizuku.Shizuku")
            val method = cls.getMethod("requestPermission", Int::class.javaPrimitiveType)
            method.invoke(null, SHIZUKU_REQUEST_CODE)
        } catch (e: Exception) {
            log("✗ 请求 Shizuku 授权失败: ${e.message}")
            finish()
        }
    }

    /**
     * 通过反射调用 Shizuku.newProcess() 获取 shell
     * 等价于内置了 adb shell
     */
    private fun shizukuExec(cmd: String): ShizukuResult {
        try {
            val shizukuCls = Class.forName("rikka.shizuku.Shizuku")
            val newProcessMethod = shizukuCls.getDeclaredMethod(
                "newProcess", Array<String>::class.java, Array<String>::class.java, String::class.java
            )
            newProcessMethod.isAccessible = true

            // 启动 sh 进程
            val process = newProcessMethod.invoke(
                null, arrayOf("sh"), null, null
            ) as Process

            // 写入命令
            val os = process.outputStream
            os.write("$cmd\n".toByteArray())
            os.write("echo ---EXIT:\$?---\n".toByteArray())
            os.write("exit\n".toByteArray())
            os.flush()

            // 读取输出
            val reader = BufferedReader(InputStreamReader(process.inputStream))
            val output = reader.readText()
            val exitCode = process.waitFor()

            // 解析退出码
            val exitMarker = "---EXIT:"
            val actualExit = if (output.contains(exitMarker)) {
                val start = output.lastIndexOf(exitMarker) + exitMarker.length
                val end = output.indexOf("---", start)
                if (end > start) output.substring(start, end).trim().toIntOrNull() else exitCode
            } else exitCode

            return ShizukuResult(actualExit ?: exitCode, output.trim())
        } catch (e: Exception) {
            log("✗ shizukuExec 异常: ${e.message}")
            return ShizukuResult(-1, e.message ?: "unknown")
        }
    }

    data class ShizukuResult(val exitCode: Int, val output: String)

    // ==================== 权限执行逻辑 ====================

    private fun executeAll() {
        var totalSuccess = 0
        var totalFail = 0

        // 第一阶段：pm grant（Android 权限）
        log(">>> 阶段1: pm grant 授予 Android 权限...")
        for (perm in pmGrantPermissions) {
            try {
                val result = shizukuExec("pm grant $PACKAGE $perm")
                if (result.exitCode == 0) {
                    totalSuccess++
                } else {
                    // pm grant 有对应权限才有效，不存在的权限会报错，忽略
                    log("  ~ $perm -> ${result.exitCode} (忽略)")
                }
            } catch (e: Exception) {
                totalFail++
            }
        }
        log("✓ pm grant 完成")

        // 第二阶段：appops set（AppOps 权限）
        log(">>> 阶段2: appops set 授予 AppOps 权限...")
        for (cmd in appOpsCommands) {
            val result = shizukuExec(cmd)
            if (result.exitCode == 0) {
                totalSuccess++
            } else {
                log("✗ $cmd -> exit=${result.exitCode}")
                totalFail++
            }
        }

        // 第三阶段：特殊系统设置（需要 settings 命令）
        log(">>> 阶段3: settings 命令修改系统设置...")
        val settingsCommands = listOf(
            // 允许安装未知来源
            "settings put secure install_non_market_apps 1",
            // 允许 USB 安装（部分设备）
            "settings put global development_settings_enabled 1",
        )
        for (cmd in settingsCommands) {
            val result = shizukuExec(cmd)
            if (result.exitCode == 0) totalSuccess++
            else log("  ~ $cmd -> ${result.exitCode}")
        }

        // 第四阶段：dpm 命令（设备管理员权限，可选）
        // 这部分需要更高级权限，暂不自动执行

        log("")
        log("========================================")
        log("全部完成！成功: $totalSuccess, 失败: $totalFail")
        log("========================================")
        log("")
        log("如需查看完整日志，请使用 logcat | grep PermOpener")

        // 显示结果 Toast
        val msg = "权限全开完成！成功 $totalSuccess 项"
        runOnUiThread { Toast.makeText(this, msg, Toast.LENGTH_LONG).show() }

        // 延迟关闭 Activity
        window?.decorView?.postDelayed({ finish() }, 3000)
    }

    private fun log(msg: String) {
        Log.d(TAG, msg)
        logLines.add(msg)
        println("[PermOpener] $msg")
    }
}

