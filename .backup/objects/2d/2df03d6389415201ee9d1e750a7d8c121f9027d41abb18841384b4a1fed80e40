package com.permopener

import android.content.pm.PackageManager
import android.os.Build
import android.os.Bundle
import android.util.Log
import android.widget.Toast
import androidx.activity.ComponentActivity
import rikka.shizuku.Shizuku

/**
 * PermOpener v2.1 - 权限全开工具
 *
 * 参考 FloatRunner 完全相同的逻辑：
 * 1. 不预先检查 Shizuku 是否可用（就算服务尚未连接，Shizuku 也会缓存请求）
 * 2. 进来直接请求授权（用户从未授权时自动弹窗，已授权则立即回调）
 * 3. 监听器回调中直接调用 ShizukuShell.exec 执行命令
 * 4. 执行完毕自动关闭
 */
class MainActivity : ComponentActivity() {

    companion object {
        private const val TAG = "PermOpener"
        private const val REQUEST_CODE = 1001
        private const val PKG = "com.permopener"

        private val PM_GRANTS = listOf(
            "android.permission.ACCESS_FINE_LOCATION",
            "android.permission.ACCESS_COARSE_LOCATION",
            "android.permission.READ_EXTERNAL_STORAGE",
            "android.permission.WRITE_EXTERNAL_STORAGE",
            "android.permission.CAMERA",
            "android.permission.RECORD_AUDIO",
            "android.permission.READ_PHONE_STATE",
            "android.permission.CALL_PHONE",
            "android.permission.READ_CALL_LOG",
            "android.permission.WRITE_CALL_LOG",
            "android.permission.ADD_VOICEMAIL",
            "android.permission.USE_SIP",
            "android.permission.SEND_SMS",
            "android.permission.RECEIVE_SMS",
            "android.permission.READ_SMS",
            "android.permission.RECEIVE_WAP_PUSH",
            "android.permission.RECEIVE_MMS",
            "android.permission.READ_CONTACTS",
            "android.permission.WRITE_CONTACTS",
            "android.permission.GET_ACCOUNTS",
            "android.permission.READ_CALENDAR",
            "android.permission.WRITE_CALENDAR",
            "android.permission.BODY_SENSORS",
            "android.permission.ACTIVITY_RECOGNITION",
            "android.permission.POST_NOTIFICATIONS",
            "android.permission.BLUETOOTH",
            "android.permission.BLUETOOTH_ADMIN",
            "android.permission.NFC",
            "android.permission.VIBRATE",
            "android.permission.FOREGROUND_SERVICE",
            "android.permission.ACCESS_NETWORK_STATE",
            "android.permission.ACCESS_WIFI_STATE",
            "android.permission.CHANGE_WIFI_STATE",
            "android.permission.CHANGE_NETWORK_STATE",
            "android.permission.FOREGROUND_SERVICE_LOCATION",
            "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
            "android.permission.FOREGROUND_SERVICE_CAMERA",
            "android.permission.FOREGROUND_SERVICE_MICROPHONE",
            "android.permission.ANSWER_PHONE_CALLS",
            "android.permission.BLUETOOTH_CONNECT",
            "android.permission.BLUETOOTH_SCAN",
            "android.permission.BLUETOOTH_ADVERTISE",
        )

        private val APP_OPS = listOf(
            "android:mock_location",
            "android:post_notifications",
            "SYSTEM_ALERT_WINDOW",
            "WRITE_SETTINGS",
            "START_ACTIVITY_BACKGROUND",
            "START_FOREGROUND",
            "GET_USAGE_STATS",
            "REQUEST_INSTALL_PACKAGES",
            "GET_NOTIFICATION",
            "MANAGE_EXTERNAL_STORAGE",
            "android:camera",
            "android:record_audio",
            "android:fine_location",
            "android:read_phone_state",
            "WAKE_LOCK",
            "android:body_sensors",
        )

        private val SETTINGS_CMDS = listOf(
            "settings put secure install_non_market_apps 1",
            "settings put global development_settings_enabled 1",
        )
    }

    private var listener: Shizuku.OnRequestPermissionResultListener? = null

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        log("")
        log("╔════════════════════════════════════╗")
        log("║  PermOpener v2.1 — 内置adb全自动  ║")
        log("╚════════════════════════════════════╝")
        log("设备: ${Build.MODEL} / SDK ${Build.VERSION.SDK_INT}")

        // 不预先检查 isAvailable，直接请求授权
        // 这样即使 Shizuku 服务尚未连接，也会缓存请求
        if (Shizuku.checkSelfPermission() == PackageManager.PERMISSION_GRANTED) {
            log("✓ Shizuku 已有授权，直接执行")
            executeAll()
            return
        }

        log("→ Shizuku 未授权，请求授权中...")
        log("  如果弹出授权对话框，请点击「允许」")

        // 注册监听器
        listener = Shizuku.OnRequestPermissionResultListener { code, result ->
            if (code == REQUEST_CODE) {
                if (result == PackageManager.PERMISSION_GRANTED) {
                    log("✓ Shizuku 授权成功！开始执行权限授予...")
                    executeAll()
                } else {
                    log("✗ Shizuku 授权被拒绝")
                    toast("Shizuku 授权被拒绝")
                    finishAfter(3000)
                }
            }
        }
        Shizuku.addRequestPermissionResultListener(listener!!)
        Shizuku.requestPermission(REQUEST_CODE)
    }

    private fun executeAll() {
        var ok = 0
        var fail = 0

        // 阶段1: pm grant
        log("")
        log("── 阶段1: pm grant ──")
        for (perm in PM_GRANTS) {
            val r = ShizukuShell.exec("pm grant $PKG $perm")
            if (r.exitCode == 0) {
                ok++
            } else {
                fail++
                log("  ✗ $perm → exit=${r.exitCode}")
                if (r.output.isNotBlank()) log("     ${r.output.take(100)}")
            }
        }
        log("  pm grant: 成功=$ok 失败=$fail")

        // 阶段2: appops set
        log("")
        log("── 阶段2: appops set ──")
        for (op in APP_OPS) {
            val r = ShizukuShell.exec("appops set $PKG $op allow")
            if (r.exitCode == 0) {
                ok++
            } else {
                fail++
                log("  ✗ $op → exit=${r.exitCode}")
                if (r.output.isNotBlank()) log("     ${r.output.take(100)}")
            }
        }
        log("  appops set: 累计成功=$ok 累计失败=$fail")

        // 阶段3: settings
        log("")
        log("── 阶段3: settings ──")
        for (cmd in SETTINGS_CMDS) {
            val r = ShizukuShell.exec(cmd)
            if (r.exitCode == 0) ok++ else {
                fail++
                log("  ✗ $cmd → exit=${r.exitCode}")
            }
        }
        log("  settings: 累计成功=$ok 累计失败=$fail")

        // 汇总
        log("")
        log("╔════════════════════════════════════╗")
        log("║  全部完成！                        ║")
        log("║  成功: $ok  失败: $fail              ║")
        log("╚════════════════════════════════════╝")
        log("")
        log("查看完整日志: adb logcat -s PermOpener")

        toast("权限全开完成！成功 $ok 项 失败 $fail 项")
        finishAfter(4000)
    }

    override fun onDestroy() {
        if (listener != null) {
            try { Shizuku.removeRequestPermissionResultListener(listener!!) } catch (_: Exception) {}
        }
        super.onDestroy()
    }

    private fun log(msg: String) { Log.d(TAG, msg) }

    private fun toast(msg: String) {
        try {
            runOnUiThread {
                val t = Toast.makeText(this, msg, Toast.LENGTH_LONG)
                t.show()
                // 等 toast 显示完再 finish
                t.view?.postDelayed({ try { finish() } catch (_: Exception) {} }, 3500)
            }
        } catch (_: Exception) {}
    }

    private fun finishAfter(ms: Long) {
        window?.decorView?.postDelayed({ 
            try { finish() } catch (_: Exception) {} 
        }, ms)
    }
}
