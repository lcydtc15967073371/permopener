    private var listener: Shizuku.OnRequestPermissionResultListener? = null
    private lateinit var tvLog: TextView
    private lateinit var svLog: ScrollView
    private val logBuffer = StringBuilder()

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        tvLog = TextView(this).apply {
            textSize = 11f
            isVerticalScrollBarEnabled = true
            setTextColor(Color.WHITE)
            setBackgroundColor(Color.parseColor("#1A1A2E"))
            setPadding(16, 16, 16, 16)
            typeface = android.graphics.Typeface.MONOSPACE
        }
        svLog = ScrollView(this).apply {
            addView(tvLog, ViewGroup.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.MATCH_PARENT))
        }
        setContentView(svLog)

        l("")
        l("╔════════════════════════════════════╗")
        l("║  PermOpener v3.3                   ║")
        l("║  标准 + 厂商命令双格式             ║")
        l("╚════════════════════════════════════╝")
        l("设备: ${Build.MODEL} / SDK ${Build.VERSION.SDK_INT}")
        l("")

        if (Shizuku.checkSelfPermission() == PackageManager.PERMISSION_GRANTED) {
            l("✓ Shizuku 已有授权，立即执行...")
            runAll()
            return
        }

        l("→ Shizuku 未授权，请求授权中...")
        l("  请在 Shizuku 对话框中点击「允许」")

        listener = Shizuku.OnRequestPermissionResultListener { code, result ->
            if (code == REQUEST_CODE) {
                if (result == PackageManager.PERMISSION_GRANTED) {
                    l("✓ Shizuku 授权成功！")
                    runAll()
                } else {
                    l("✗ Shizuku 授权被拒绝")
                    l("请重新打开应用并允许授权")
                    saveLogFile()
                }
            }
        }
        Shizuku.addRequestPermissionResultListener(listener!!)
        Shizuku.requestPermission(REQUEST_CODE)
    }

    private fun runAll() {
        var ok = 0
        var fail = 0

        // 阶段1: pm grant
        l("")
        l("── 阶段1: pm grant ──")
        for (perm in PM_GRANTS) {
            val r = ShizukuShell.exec("pm grant $PKG $perm")
            if (r.exitCode == 0) ok++ else { fail++; l("  ✗ $perm") }
        }
        l("  pm grant: 成功=$ok 失败=$fail")

        // 阶段2: 标准 appops（带 android: 前缀）
        l("")
        l("── 阶段2: 标准 appops ──")
        for (op in STANDARD_OPS) {
            val r = ShizukuShell.exec("appops set $PKG $op allow")
            if (r.exitCode == 0) ok++ else { fail++; l("  ✗ $op") }
        }
        l("  标准 appops: 成功=$ok 失败=$fail")

        // 阶段3: 厂商命令（不带 android: 前缀）
        l("")
        l("── 阶段3: 厂商命令 ──")
        for (op in VENDOR_OPS) {
            val r = ShizukuShell.exec("appops set $PKG $op allow")
            if (r.exitCode == 0) ok++ else { fail++; l("  ✗ $op") }
        }
        l("  厂商命令: 成功=$ok 失败=$fail")

        // 阶段4: settings
        l("")
        l("── 阶段4: settings ──")
        for (cmd in SETTINGS_CMDS) {
            val r = ShizukuShell.exec(cmd)
            if (r.exitCode == 0) ok++ else fail++
        }
        l("  settings: 成功=$ok 失败=$fail")

        // 汇总
        l("")
        l("╔════════════════════════════════════╗")
        l("║  全部完成！                        ║")
        l("║  成功: $ok  失败: $fail              ║")
        l("╚════════════════════════════════════╝")
        l("")
        l("完整日志已保存到:")
        l("  $LOG_FILE")
        l("")
        l("提示：部分权限需重启 App 后生效")
        l("可手动关闭此页面")

        saveLogFile()

        try {
            runOnUiThread {
                Toast.makeText(this, "完成！成功 $ok 项 失败 $fail 项", Toast.LENGTH_LONG).show()
            }
        } catch (_: Exception) {}
    }

    private fun l(msg: String) {
        Log.d(TAG, msg)
        logBuffer.append("$msg\n")
        runOnUiThread {
            tvLog.append("$msg\n")
            svLog.post { svLog.fullScroll(ScrollView.FOCUS_DOWN) }
        }
    }

    private fun saveLogFile() {
        try {
            File(LOG_FILE).parentFile?.mkdirs()
            FileWriter(LOG_FILE).use { it.write(logBuffer.toString()) }
            Log.d(TAG, "日志已保存到 $LOG_FILE")
        } catch (e: Exception) {
            Log.e(TAG, "保存日志失败: ${e.message}")
            try {
                val internalFile = File(filesDir, "permopener_log.txt")
                FileWriter(internalFile).use { it.write(logBuffer.toString()) }
            } catch (_: Exception) {}
        }
    }

    override fun onDestroy() {
        if (listener != null) {
            try { Shizuku.removeRequestPermissionResultListener(listener!!) } catch (_: Exception) {}
        }
        super.onDestroy()
    }
