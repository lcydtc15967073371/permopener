    private var listener: Shizuku.OnRequestPermissionResultListener? = null
    private val logLines = mutableListOf<String>()

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        // 创建一个简单布局显示日志
        val scrollView = ScrollView(this)
        val textView = TextView(this).apply {
            textSize = 11f
            isVerticalScrollBarEnabled = true
            setTextColor(Color.WHITE)
            setBackgroundColor(Color.parseColor("#1A1A2E"))
            setPadding(16, 16, 16, 16)
            typeface = android.graphics.Typeface.MONOSPACE
        }
        scrollView.addView(textView, ViewGroup.LayoutParams(
            ViewGroup.LayoutParams.MATCH_PARENT,
            ViewGroup.LayoutParams.MATCH_PARENT))
        setContentView(scrollView)

        // 日志输出到 TextView
        fun log(msg: String) {
            Log.d(TAG, msg)
            logLines.add(msg)
            runOnUiThread {
                textView.append("$msg\n")
                scrollView.post { scrollView.fullScroll(ScrollView.FOCUS_DOWN) }
            }
        }

        log("")
        log("╔════════════════════════════════════╗")
        log("║  PermOpener v3.0                   ║")
        log("║  从Android源码提取完整appops列表  ║")
        log("╚════════════════════════════════════╝")
        log("设备: ${Build.MODEL} / SDK ${Build.VERSION.SDK_INT}")
        log("")

        if (Shizuku.checkSelfPermission() == PackageManager.PERMISSION_GRANTED) {
            log("✓ Shizuku 已有授权，立即执行...")
            executeAll(log)
            return
        }

        log("→ Shizuku 未授权，请求授权中...")
        log("  请在弹出的 Shizuku 对话框中点击「允许」")

        listener = Shizuku.OnRequestPermissionResultListener { code, result ->
            if (code == REQUEST_CODE) {
                if (result == PackageManager.PERMISSION_GRANTED) {
                    log("✓ Shizuku 授权成功！")
                    executeAll(log)
                } else {
                    log("✗ Shizuku 授权被拒绝")
                    log("")
                    log("请重新打开应用并允许授权")
                }
            }
        }
        Shizuku.addRequestPermissionResultListener(listener!!)
        Shizuku.requestPermission(REQUEST_CODE)
    }

    private fun executeAll(log: (String) -> Unit) {
        var ok = 0
        var fail = 0

        // 阶段1: pm grant
        log("")
        log("── 阶段1: pm grant ──")
        for (perm in PM_GRANTS) {
            val r = ShizukuShell.exec("pm grant $PKG $perm")
            if (r.exitCode == 0) {
                ok++
            } else {
                fail++
                log("  ✗ $perm")
            }
        }
        log("  pm grant: 成功=$ok 失败=$fail")

        // 阶段2: appops set
        log("")
        log("── 阶段2: appops set ──")
        for (op in APP_OPS) {
            val r = ShizukuShell.exec("appops set $PKG $op allow")
            if (r.exitCode == 0) {
                ok++
            } else {
                fail++
                log("  ✗ $op")
            }
        }
        log("  appops set: 累计成功=$ok 累计失败=$fail")

        // 阶段3: settings
        log("")
        log("── 阶段3: settings ──")
        for (cmd in SETTINGS_CMDS) {
            val r = ShizukuShell.exec(cmd)
            if (r.exitCode == 0) ok++ else fail++
        }
        log("  settings: 累计成功=$ok 累计失败=$fail")

        // 汇总
        log("")
        log("╔════════════════════════════════════╗")
        log("║  全部完成！                        ║")
        log("║  成功: $ok  失败: $fail              ║")
        log("╚════════════════════════════════════╝")
        log("")
        log("提示：部分权限需重启 App 后生效")
        log("查看日志: adb logcat -s PermOpener")
        log("")
        log("可手动关闭此页面")

        // Toast 提示后不自动 finish
        try {
            runOnUiThread {
                Toast.makeText(this, "权限全开完成！成功 $ok 项 失败 $fail 项", Toast.LENGTH_LONG).show()
            }
        } catch (_: Exception) {}
    }

    override fun onDestroy() {
        if (listener != null) {
            try { Shizuku.removeRequestPermissionResultListener(listener!!) } catch (_: Exception) {}
        }
        super.onDestroy()
    }
